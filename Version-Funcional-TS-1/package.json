{
  "name": "pdf-generator",
  "version": "1.0.0",
  "description": "Generador de PDFs corporativos con Puppeteer y TypeScript",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build":   "tsc",
    "dev":     "ts-node src/cli.ts",
    "invoice": "ts-node src/cli.ts --type invoice",
    "report":  "ts-node src/cli.ts --type report",
    "tables":  "ts-node src/cli.ts --type tables"
  },
  "dependencies": {
    "puppeteer": "^21.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node":     "^10.9.0",
    "typescript":  "^5.3.0"
  }
}
